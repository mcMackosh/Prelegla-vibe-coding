DATABASE_URL="file:./dev.db"
PORT=3001
FRONTEND_ORIGIN="http://localhost:3000"

# Signs auth JWTs. Fine to leave as a fixed dev value: per KAN-5 the database
# (and any accounts/sessions in it) resets on every server restart anyway.
JWT_SECRET="dev-insecure-secret-change-me"

# OPENROUTER_API_KEY is read from the repo-root .env, not this file (see CLAUDE.md).
OPENROUTER_MODEL="openai/gpt-oss-20b:free"
